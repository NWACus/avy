{
  "cli": {
    "version": ">= 7.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "main": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "main",
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "adhoc": {
      "distribution": "internal",
      "channel": "main",
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "simulator": {
      "distribution": "internal",
      "channel": "main",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "preview": {
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "release": {
      "channel": "release",
      "autoIncrement": true
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "appleId": "developer@nwac.us",
        "appleTeamId": "RKM3ZE73JR",
        "ascAppId": "6444379522"
      },
      "android": {
        "track": "internal"
      }
    },
    "release": {
      "ios": {
        "appleId": "IOS_USER_ID",
        "appleTeamId": "IOS_TEAM_ID",
        "ascAppId": "IOS_APP_ID"
      }
    }
  }
}